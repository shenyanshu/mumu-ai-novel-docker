# MuMuAINovel 配置文件
# 修改后需要重启应用才能生效

[database]
# SQLite 数据库（嵌入式，无需独立服务器）
# 格式：sqlite+aiosqlite:///数据库文件路径
url = sqlite+aiosqlite:///./data/mumuai.db

[app]
# 应用配置
host = 0.0.0.0
port = 8000
debug = false

[ai]
# AI 服务配置（可选）
# OpenAI 配置
openai_api_key = 
openai_base_url = 

# Anthropic Claude 配置
anthropic_api_key = 
anthropic_base_url = 

# Google Gemini 配置
gemini_api_key = 
gemini_base_url = 

[auth]
# 本地账户登录配置
local_auth_enabled = true
local_auth_username = admin
local_auth_password = admin123

