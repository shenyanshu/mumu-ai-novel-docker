# =============================
# MuMuAINovel Docker 环境变量模板（生产）
# 复制为 .env 后按需修改
# =============================

# 基础应用
MUMUAINOVEL_IMAGE=ghcr.io/shenyanshu/mumu-ai-novel-docker:latest
APP_NAME=MuMuAINovel
APP_VERSION=1.0.0
APP_PORT=8000
DEBUG=false
TZ=Asia/Shanghai

# 前端访问地址（用于 OAuth 回调等）
FRONTEND_URL=http://localhost:8000

# SQLite 数据库文件路径
DATABASE_PATH=./data/mumuai.db

# 数据库连接串（留空则自动使用 SQLite 嵌入式数据库）
DATABASE_URL=

# 数据库连接池
DATABASE_POOL_SIZE=30
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=60
DATABASE_POOL_RECYCLE=1800
DATABASE_POOL_PRE_PING=True
DATABASE_POOL_USE_LIFO=True

# 代理（可选）
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1

# AI 服务（按需填写）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
GEMINI_API_KEY=
GEMINI_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
DEFAULT_AI_PROVIDER=openai
DEFAULT_MODEL=gpt-4o-mini
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=2000

# LinuxDO OAuth（可选）
LINUXDO_CLIENT_ID=
LINUXDO_CLIENT_SECRET=
LINUXDO_REDIRECT_URI=http://localhost:8000/api/auth/linuxdo/callback

# 本地账户
LOCAL_AUTH_ENABLED=true
LOCAL_AUTH_USERNAME=admin
LOCAL_AUTH_DISPLAY_NAME=本地管理员

# 会话配置
SESSION_EXPIRE_MINUTES=120
SESSION_REFRESH_THRESHOLD_MINUTES=30

# 敏感信息通过 secrets 文件提供（Docker 部署时）
# secrets/local_auth_password.txt
